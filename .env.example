# LLM API Keys (必填)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 可选：Ollama 配置（如果使用本地模型）
OLLAMA_BASE_URL=http://localhost:11434

# 应用配置
LOG_LEVEL=INFO
QUALITY_THRESHOLD=0.8
MAX_RETRIES=3
SANDBOX_TIMEOUT=30

# 存储路径
DATA_DIR=./data
WORKSPACE_DIR=./workspace
OUTPUT_DIR=./output
LOG_DIR=./logs
